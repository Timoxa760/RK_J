# MoneyMind Environment Variables

# App
# false = phone+password auth (Postgres); true = demo shortcuts elsewhere
DEMO_MODE=false

# JWT (must match api-gateway, user-service, ai-processor)
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TTL=4h

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/moneymind?sslmode=disable

# Redis (password reset codes; optional — falls back to in-memory)
REDIS_URL=redis://localhost:6379/0
OTP_TTL=300

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=clickhouse_user
CLICKHOUSE_PASSWORD=clickhouse_password
CLICKHOUSE_DB=default

# Kafka
KAFKA_URL=localhost:9092
KAFKA_BROKERS=localhost:9092

# Google Gemini (LLM — advisor, expense parse, credit PDF)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Whisper (docker compose --profile ai up -d whisper)
WHISPER_URL=http://127.0.0.1:9001
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1

# Encryption key for provider credentials (AES-256-GCM, 32 bytes)
ENCRYPTION_KEY=change-me-to-a-32-char-key-for-aes!

# Advisor / profile file-store (shared Docker volume path)
PROFILE_DATA_DIR=
CREDIT_DATA_DIR=

# RuCaptcha (FNS MCO, only when DEMO_MODE=false)
RUCAPTCHA_KEY=
MCO_TOKEN_DIR=mco_tokens

# OAuth2 (email receipts)
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_MAIL_CLIENT_ID=
OAUTH_MAIL_CLIENT_SECRET=

# Credit PDF demo fallback (only DEMO_MODE=true)
CREDIT_SCAN_DEMO_AMOUNT=1200000
CREDIT_SCAN_DEMO_RATE=14.5
CREDIT_SCAN_DEMO_TERM=36
CREDIT_SCAN_DEMO_PAYMENT=42000
CREDIT_SCAN_DEMO_BANK=Т-Банк

# Local gateway without Docker DNS (optional)
# USER_SERVICE_URL=http://127.0.0.1:8001
# RECEIPT_SERVICE_URL=http://127.0.0.1:8002
# AI_PROCESSOR_URL=http://127.0.0.1:8100
