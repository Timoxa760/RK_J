# MoneyMind Environment Variables

# App
DEMO_MODE=true

# Локальный запуск gateway без Docker DNS (опционально)
# USER_SERVICE_URL=http://127.0.0.1:8001
# RECEIPT_SERVICE_URL=http://127.0.0.1:8002
# SCRAPER_SERVICE_URL=http://127.0.0.1:8003
# AI_PROCESSOR_URL=http://127.0.0.1:8100
# CREDIT_SERVICE_URL=http://127.0.0.1:8009
# ANALYTICS_SERVICE_URL=http://127.0.0.1:8101
# GOAL_SERVICE_URL=http://127.0.0.1:8006
# REPORTING_SERVICE_URL=http://127.0.0.1:8010

# JWT (access token TTL — по умолчанию 4ч; для длинного онбординга)
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TTL=4h

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/moneymind?sslmode=disable

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=clickhouse_user
CLICKHOUSE_PASSWORD=clickhouse_password
CLICKHOUSE_DB=default

# Redis
REDIS_URL=localhost:6379

# Kafka
KAFKA_URL=localhost:9092

# OnlySQ (LLM, OpenAI-compatible)
ONLYSQ_BASE_URL=https://api.onlysq.ru/v1
ONLYSQ_API_KEY=
ONLYSQ_MODEL=gpt-4o-mini

# Whisper (OpenAI-compatible STT; docker compose profile ai, host port 9001)
WHISPER_URL=http://127.0.0.1:9001
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1

# Encryption key for provider credentials (AES-256-GCM, 32 bytes)
ENCRYPTION_KEY=change-me-to-a-32-char-key-for-aes!

# RuCaptcha (for FNS МОИ ЧЕКИ captcha solving)
RUCAPTCHA_KEY=
# Directory to store FNS MCO auth tokens (per phone)
MCO_TOKEN_DIR=mco_tokens

# 2Captcha (for Lenta provider)
2CAPTCHA_API_KEY=

# OAuth2
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_MAIL_CLIENT_ID=
OAUTH_MAIL_CLIENT_SECRET=
